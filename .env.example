# DeepSeek chat model settings (required for query / grading)
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Embedding model settings (Alibaba DashScope by default)
EMBEDDING_API_KEY=your-dashscope-api-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024

# Vector store directory (optional)
CHROMA_PERSIST_DIR=./chroma_db

# Maximum number of documents to retrieve per query (optional)
RETRIEVER_TOP_K=4
RETRIEVAL_MAX_HOPS=2
MIN_RELEVANT_CHUNKS_TO_ANSWER=2

# FastAPI settings (optional)
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false
