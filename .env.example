# OpenAI API key (required)
OPENAI_API_KEY=sk-...

# OpenAI model settings (optional, defaults shown)
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Vector store directory (optional)
CHROMA_PERSIST_DIR=./chroma_db

# Maximum number of documents to retrieve per query (optional)
RETRIEVER_TOP_K=4

# FastAPI settings (optional)
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false
